{
  "name": "mac-use-mcp",
  "version": "0.1.0",
  "description": "Zero-dependency macOS desktop automation via MCP",
  "license": "MIT",
  "author": "antbotlab",
  "type": "module",
  "bin": {
    "mac-use-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "os": [
    "darwin"
  ],
  "scripts": {
    "build": "tsc",
    "build:swift": "bash scripts/build-swift.sh",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublishOnly": "pnpm run build:swift && pnpm run build"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^22.13.9",
    "eslint": "^9.21.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.56.1"
  },
  "keywords": [
    "mcp",
    "macos",
    "automation",
    "desktop",
    "screenshot",
    "computer-use",
    "gui",
    "ai-agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/antbotlab/mac-use-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/antbotlab/mac-use-mcp/issues"
  },
  "homepage": "https://github.com/antbotlab/mac-use-mcp#readme"
}
